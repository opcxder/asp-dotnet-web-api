@model Basic_Frontend.Models.Product

<h2>Edit Product</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />  
    @*our backend need the id to fetch the exiting data and then update that data.*@

    <div>
        <label>Name</label>
        <input asp-for="Name" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Description" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Price" />
    </div>

    <button type="submit">Update</button>

</form>